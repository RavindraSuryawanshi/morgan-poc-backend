{
    "Logging": {
        "LogLevel": {
            "Default": "Information",
            "Microsoft.AspNetCore": "Warning"
        }
    },
    "AllowedHosts": "*",

    "OutboxPublisher": {
        "BatchSize": 100,
        "PollingIntervalSeconds": 10,
        "MaxRetryCount": 5
    },

    "ServiceBus": {        
        "TopicName": "user-events"
    },

    "Salesforce": {
        "InstanceUrl": "https://login.salesforce.com",
        "ClientId": "",
        "ClientSecret": "",
        "Username": "",
        "Password": "",
        "SecurityToken": "",
        "ApiVersion": "v61.0",
        "ObjectName": "Customer__c"
    },

    "Serilog": {
        "MinimumLevel": {
            "Default": "Information",
            "Override": {
                "Microsoft": "Warning",
                "System": "Warning"
            }
        }
    },

    "ApplicationName": "Morgan.SalesforceSyncPOC.WebAPI",
    "KeyVaultUrl": "https://kv-morgan-poc-dev.vault.azure.net/"
}
